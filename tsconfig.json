{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "node",
    "jsx": "react-jsx",
    "baseUrl": ".",
    "types": ["vite/client"],
    "skipLibCheck": true,
    "strict": true,
    "resolveJsonModule": true
  },
  "include": ["resources/**/*.ts", "resources/**/*.tsx", "vite.config.ts"],
  "exclude": ["node_modules", "dist"]
}
